<!doctype html>
<html lang="ja">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>ログビューア</title>
  <style>
    :root {
      --bg: #f5f7fb;
      --panel: #ffffff;
      --border: #d6dbe6;
      --text: #1f2937;
      --muted: #6b7280;
      --accent: #2563eb;
      --danger: #dc2626;
      --shadow: 0 8px 20px rgba(0,0,0,.08);
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: var(--bg);
      color: var(--text);
      height: 100vh;
      overflow: hidden;
    }
    .app {
      display: grid;
      grid-template-columns: 330px 1fr;
      height: 100vh;
      min-width: 960px;
    }
    aside {
      background: var(--panel);
      border-right: 1px solid var(--border);
      padding: 14px;
      overflow: auto;
    }
    main {
      display: grid;
      grid-template-rows: auto 1fr auto;
      min-width: 0;
      height: 100vh;
    }
    .toolbar {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      background: var(--panel);
      border-bottom: 1px solid var(--border);
      padding: 10px 12px;
    }
    h1 {
      font-size: 17px;
      margin: 0 0 12px;
    }
    .section {
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 12px;
      margin-bottom: 12px;
      background: #fff;
      box-shadow: 0 1px 2px rgba(0,0,0,.03);
    }
    .section-title {
      font-size: 13px;
      font-weight: 700;
      margin-bottom: 8px;
    }
    .drop-zone {
      border: 2px dashed #aab3c4;
      border-radius: 12px;
      padding: 14px;
      text-align: center;
      color: var(--muted);
      background: #fafbff;
      transition: .15s ease;
      font-size: 13px;
    }
    .drop-zone.dragover {
      border-color: var(--accent);
      background: #eff6ff;
      color: var(--accent);
    }
    .keyword-row {
      display: grid;
      grid-template-columns: 1fr 32px 32px 38px;
      gap: 5px;
      align-items: center;
      margin-bottom: 8px;
    }
    .keyword-row input[type="text"] {
      min-width: 0;
      width: 100%;
      padding: 7px 8px;
      border: 1px solid var(--border);
      border-radius: 8px;
      font-size: 13px;
    }
    .keyword-row input[type="color"] {
      width: 38px;
      height: 32px;
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 2px;
      background: #fff;
    }
    button, .file-label {
      border: 1px solid var(--border);
      background: #fff;
      color: var(--text);
      border-radius: 8px;
      padding: 7px 10px;
      font-size: 13px;
      cursor: pointer;
      user-select: none;
    }
    button:hover, .file-label:hover { background: #f3f4f6; }
    button.primary { background: var(--accent); color: #fff; border-color: var(--accent); }
    button.primary:hover { filter: brightness(.96); }
    button.danger { color: var(--danger); }
    .compact-btn { padding: 6px 0; text-align: center; }
    label.check {
      display: flex;
      align-items: center;
      gap: 7px;
      font-size: 13px;
      margin: 7px 0;
    }
    .hint {
      color: var(--muted);
      font-size: 12px;
      line-height: 1.5;
    }
    .status {
      border-top: 1px solid var(--border);
      background: #fff;
      padding: 7px 12px;
      color: var(--muted);
      font-size: 12px;
      display: flex;
      justify-content: space-between;
      gap: 12px;
    }
    #editorHost { min-height: 0; overflow: hidden; }
    .cm-editor {
      height: 100%;
      font-size: 14px;
      background: #fff;
    }
    .cm-scroller {
      font-family: Consolas, "Cascadia Mono", "Noto Sans Mono", monospace;
    }
    .wrap-on .cm-content { white-space: pre-wrap; word-break: break-word; }
    .wrap-on .cm-line { white-space: pre-wrap; word-break: break-word; }
    .wrap-off .cm-content { white-space: pre; }
    .wrap-off .cm-scroller { overflow-x: auto; }
    .invalid-regex {
      outline: 2px solid #ef4444;
      outline-offset: 1px;
    }
    input[type="file"] { display: none; }
    .button-row { display: flex; gap: 8px; flex-wrap: wrap; }
    .small-input {
      width: 100%;
      padding: 7px 8px;
      border: 1px solid var(--border);
      border-radius: 8px;
      font-size: 13px;
      margin-top: 6px;
    }
  </style>
</head>
<body>
  <div class="app">
    <aside>
      <h1>ログビューア兼テキストエディタ</h1>

      <div class="section">
        <div class="section-title">ファイル読み込み</div>
        <div id="dropZone" class="drop-zone">ここにテキストファイルをドラッグ＆ドロップ</div>
        <div class="button-row" style="margin-top:10px;">
          <label class="file-label" for="fileInput">ファイルを開く</label>
          <input id="fileInput" type="file" accept=".txt,.log,.csv,.json,.xml,.ini,.md,.html,.css,.js,text/*" />
          <button id="newBtn">新規</button>
        </div>
      </div>

      <div class="section">
        <div class="section-title">検索キーワード</div>
        <div id="keywordList"></div>
        <label class="check"><input id="regexMode" type="checkbox" checked /> 正規表現検索</label>
        <label class="check"><input id="caseSensitive" type="checkbox" /> 大文字小文字を区別</label>
        <div class="hint">↑/↓ボタンでカーソル位置の前後を検索。F3で次、Shift+F3で前を検索します。対象は直前に検索したキーワードです。</div>
      </div>

      <div class="section">
        <div class="section-title">表示</div>
        <label class="check"><input id="wrapToggle" type="checkbox" /> 右端で折り返す</label>
        <div class="hint">初期状態は折り返しなしです。長い行は横スクロールできます。</div>
      </div>

      <div class="section">
        <div class="section-title">保存</div>
        <input id="saveName" class="small-input" value="edited_log" placeholder="保存ファイル名" />
        <div class="button-row" style="margin-top:10px;">
          <button id="saveTextBtn" class="primary">TXT保存</button>
          <button id="saveHtmlBtn" class="primary">HTML保存</button>
        </div>
        <div class="hint" style="margin-top:8px;">HTML保存では現在のキーワード色を反映します。</div>
      </div>

      <div class="section">
        <div class="section-title">設定</div>
        <div class="button-row">
          <button id="saveSettingsBtn">設定を保存</button>
          <button id="resetSettingsBtn" class="danger">設定リセット</button>
        </div>
        <div class="hint" style="margin-top:8px;">キーワード、色、正規表現、折り返し設定はlocalStorageに保存されます。</div>
      </div>
    </aside>

    <main>
      <div class="toolbar">
        <button id="copyBtn">全コピー</button>
        <button id="selectAllBtn">全選択</button>
        <button id="clearHighlightsBtn">検索語をクリア</button>
        <span class="hint">CodeMirror 6 / ローカルHTML</span>
      </div>
      <div id="editorHost" class="wrap-off"></div>
      <div class="status">
        <span id="statusLeft">準備完了</span>
        <span id="statusRight">0 行 / 0 文字</span>
      </div>
    </main>
  </div>

  <script type="module">
    import {EditorState, StateEffect, StateField} from "https://esm.sh/@codemirror/state@6";
    import {EditorView, keymap, lineNumbers, highlightActiveLine, Decoration} from "https://esm.sh/@codemirror/view@6";
    import {defaultKeymap, history, historyKeymap} from "https://esm.sh/@codemirror/commands@6";
    import {searchKeymap} from "https://esm.sh/@codemirror/search@6";

    const STORAGE_KEY = "localLogEditorCodeMirrorSettings.v1";
    const defaultKeywords = [
      { text: "", color: "#90ee90", label: "キーワード1" },
      { text: "", color: "#ffff00", label: "キーワード2" },
      { text: "", color: "#ffa500", label: "キーワード3" },
      { text: "", color: "#87ceeb", label: "キーワード4" },
      { text: "", color: "#ffc0cb", label: "キーワード5" },
    ];

    let settings = loadSettings();
    let lastSearchIndex = 0;
    let lastFileName = "";

    const keywordList = document.getElementById("keywordList");
    const regexMode = document.getElementById("regexMode");
    const caseSensitive = document.getElementById("caseSensitive");
    const wrapToggle = document.getElementById("wrapToggle");
    const editorHost = document.getElementById("editorHost");
    const statusLeft = document.getElementById("statusLeft");
    const statusRight = document.getElementById("statusRight");
    const saveName = document.getElementById("saveName");

    const setHighlightsEffect = StateEffect.define();
    const highlightField = StateField.define({
      create() { return Decoration.none; },
      update(value, tr) {
        value = value.map(tr.changes);
        for (const e of tr.effects) {
          if (e.is(setHighlightsEffect)) return e.value;
        }
        if (tr.docChanged) return buildDecorations(tr.state);
        return value;
      },
      provide: f => EditorView.decorations.from(f)
    });

    const updateListener = EditorView.updateListener.of(update => {
      if (update.docChanged || update.selectionSet) {
        updateStatus();
        if (update.docChanged) scheduleHighlightRefresh();
      }
    });

    const view = new EditorView({
      state: EditorState.create({
        doc: "",
        extensions: [
          lineNumbers(),
          history(),
          highlightActiveLine(),
          keymap.of([...defaultKeymap, ...historyKeymap, ...searchKeymap]),
          EditorView.lineWrapping,
          highlightField,
          updateListener,
          EditorView.theme({
            "&": { height: "100%" },
            ".cm-content": { minHeight: "100%" },
            ".cm-line": { padding: "0 6px" }
          })
        ]
      }),
      parent: editorHost
    });

    renderKeywordRows();
    applySettingsToUi();
    refreshHighlights();
    updateStatus();

    function loadSettings() {
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) throw new Error("no settings");
        const parsed = JSON.parse(raw);
        return {
          keywords: mergeKeywords(parsed.keywords),
          regex: parsed.regex ?? true,
          caseSensitive: parsed.caseSensitive ?? false,
          wrap: parsed.wrap ?? false,
        };
      } catch {
        return {
          keywords: structuredClone(defaultKeywords),
          regex: true,
          caseSensitive: false,
          wrap: false,
        };
      }
    }

    function mergeKeywords(value) {
      return defaultKeywords.map((d, i) => ({
        ...d,
        ...(Array.isArray(value) ? value[i] : {})
      }));
    }

    function saveSettings() {
      syncSettingsFromUi();
      localStorage.setItem(STORAGE_KEY, JSON.stringify(settings));
      setStatus("設定を保存しました");
    }

    function applySettingsToUi() {
      regexMode.checked = settings.regex;
      caseSensitive.checked = settings.caseSensitive;
      wrapToggle.checked = settings.wrap;
      updateWrapClass();
    }

    function syncSettingsFromUi() {
      settings.regex = regexMode.checked;
      settings.caseSensitive = caseSensitive.checked;
      settings.wrap = wrapToggle.checked;
      settings.keywords = [...document.querySelectorAll(".keyword-row")].map((row, i) => ({
        label: defaultKeywords[i].label,
        text: row.querySelector("input[type=text]").value,
        color: row.querySelector("input[type=color]").value
      }));
    }

    function renderKeywordRows() {
      keywordList.innerHTML = "";
      settings.keywords.forEach((kw, index) => {
        const row = document.createElement("div");
        row.className = "keyword-row";
        row.dataset.index = index;

        const input = document.createElement("input");
        input.type = "text";
        input.placeholder = kw.label;
        input.value = kw.text || "";
        input.style.backgroundColor = kw.color;
        input.title = `${kw.label}（正規表現可）`;

        const prev = document.createElement("button");
        prev.className = "compact-btn";
        prev.textContent = "↑";
        prev.title = "カーソルより前を検索";
        prev.addEventListener("click", () => searchKeyword(index, -1));

        const next = document.createElement("button");
        next.className = "compact-btn";
        next.textContent = "↓";
        next.title = "カーソルより後ろを検索";
        next.addEventListener("click", () => searchKeyword(index, 1));

        const color = document.createElement("input");
        color.type = "color";
        color.value = kw.color;
        color.title = "色を変更";

        input.addEventListener("input", () => {
          input.classList.remove("invalid-regex");
          settings.keywords[index].text = input.value;
          scheduleHighlightRefresh();
          autoSaveSettings();
        });
        color.addEventListener("input", () => {
          input.style.backgroundColor = color.value;
          settings.keywords[index].color = color.value;
          scheduleHighlightRefresh();
          autoSaveSettings();
        });

        row.append(input, prev, next, color);
        keywordList.appendChild(row);
      });
    }

    let highlightTimer = 0;
    function scheduleHighlightRefresh() {
      clearTimeout(highlightTimer);
      highlightTimer = setTimeout(refreshHighlights, 120);
    }

    function refreshHighlights() {
      syncSettingsFromUi();
      const deco = buildDecorations(view.state);
      view.dispatch({ effects: setHighlightsEffect.of(deco) });
    }

    function buildDecorations(state) {
      syncSettingsFromUi();
      const text = state.doc.toString();
      const builder = [];
      document.querySelectorAll(".keyword-row input[type=text]").forEach(input => input.classList.remove("invalid-regex"));

      settings.keywords.forEach((kw, index) => {
        if (!kw.text) return;
        let regex;
        try {
          regex = makeRegex(kw.text, true);
        } catch {
          const row = document.querySelector(`.keyword-row[data-index="${index}"] input[type=text]`);
          row?.classList.add("invalid-regex");
          return;
        }
        let match;
        let safety = 0;
        while ((match = regex.exec(text)) !== null) {
          if (match[0].length === 0) {
            regex.lastIndex++;
            continue;
          }
          builder.push(Decoration.mark({
            attributes: {
              style: `background-color:${kw.color}; color:#111827; border-radius:2px;`
            }
          }).range(match.index, match.index + match[0].length));
          if (++safety > 20000) break;
        }
      });
      return Decoration.set(builder, true);
    }

    function makeRegex(pattern, global) {
      const flags = `${global ? "g" : ""}${settings.caseSensitive ? "" : "i"}`;
      if (settings.regex) return new RegExp(pattern, flags);
      return new RegExp(escapeRegex(pattern), flags);
    }

    function escapeRegex(value) {
      return value.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
    }

    function searchKeyword(index, direction) {
      syncSettingsFromUi();
      const kw = settings.keywords[index];
      if (!kw?.text) {
        setStatus(`${kw?.label || "キーワード"}が空です`);
        return;
      }
      lastSearchIndex = index;
      const text = view.state.doc.toString();
      const cursor = view.state.selection.main.head;
      let regex;
      try {
        regex = makeRegex(kw.text, true);
      } catch (e) {
        setStatus(`正規表現エラー: ${e.message}`);
        return;
      }

      const matches = [];
      let match;
      let safety = 0;
      while ((match = regex.exec(text)) !== null) {
        if (match[0].length === 0) { regex.lastIndex++; continue; }
        matches.push({ from: match.index, to: match.index + match[0].length, text: match[0] });
        if (++safety > 50000) break;
      }
      if (matches.length === 0) {
        setStatus(`見つかりません: ${kw.text}`);
        return;
      }

      let target;
      if (direction > 0) {
        target = matches.find(m => m.from > cursor) || matches[0];
      } else {
        target = [...matches].reverse().find(m => m.to < cursor) || matches[matches.length - 1];
      }
      view.dispatch({ selection: { anchor: target.from, head: target.to }, scrollIntoView: true });
      view.focus();
      setStatus(`${kw.label}: ${matches.indexOf(target) + 1}/${matches.length} を選択`);
    }

    document.addEventListener("keydown", e => {
      if (e.key === "F3") {
        e.preventDefault();
        searchKeyword(lastSearchIndex, e.shiftKey ? -1 : 1);
      }
    });

    function updateWrapClass() {
      editorHost.classList.toggle("wrap-on", wrapToggle.checked);
      editorHost.classList.toggle("wrap-off", !wrapToggle.checked);
    }

    [regexMode, caseSensitive].forEach(el => el.addEventListener("change", () => {
      syncSettingsFromUi();
      refreshHighlights();
      autoSaveSettings();
    }));
    wrapToggle.addEventListener("change", () => {
      updateWrapClass();
      syncSettingsFromUi();
      autoSaveSettings();
    });

    const dropZone = document.getElementById("dropZone");
    dropZone.addEventListener("dragover", e => {
      e.preventDefault();
      dropZone.classList.add("dragover");
    });
    dropZone.addEventListener("dragleave", () => dropZone.classList.remove("dragover"));
    dropZone.addEventListener("drop", async e => {
      e.preventDefault();
      dropZone.classList.remove("dragover");
      const file = e.dataTransfer.files?.[0];
      if (file) await openFile(file);
    });
    document.getElementById("fileInput").addEventListener("change", async e => {
      const file = e.target.files?.[0];
      if (file) await openFile(file);
      e.target.value = "";
    });

    async function openFile(file) {
      try {
        const text = await file.text();
        lastFileName = file.name;
        setDocument(text);
        saveName.value = stripExtension(file.name) || "edited_log";
        setStatus(`読み込み完了: ${file.name}`);
      } catch (e) {
        setStatus(`読み込み失敗: ${e.message}`);
      }
    }

    function setDocument(text) {
      view.dispatch({ changes: { from: 0, to: view.state.doc.length, insert: text } });
      refreshHighlights();
      updateStatus();
    }

    document.getElementById("newBtn").addEventListener("click", () => {
      if (view.state.doc.length > 0 && !confirm("現在の内容を消して新規作成しますか？")) return;
      lastFileName = "";
      setDocument("");
      setStatus("新規作成しました");
    });

    document.getElementById("saveTextBtn").addEventListener("click", () => {
      const name = safeFileName(saveName.value || stripExtension(lastFileName) || "edited_log") + ".txt";
      downloadBlob(name, new Blob([view.state.doc.toString()], { type: "text/plain;charset=utf-8" }));
      setStatus(`TXT保存: ${name}`);
    });

    document.getElementById("saveHtmlBtn").addEventListener("click", () => {
      const name = safeFileName(saveName.value || stripExtension(lastFileName) || "highlighted_log") + ".html";
      const html = buildHtmlExport();
      downloadBlob(name, new Blob([html], { type: "text/html;charset=utf-8" }));
      setStatus(`HTML保存: ${name}`);
    });

    document.getElementById("saveSettingsBtn").addEventListener("click", saveSettings);
    document.getElementById("resetSettingsBtn").addEventListener("click", () => {
      if (!confirm("キーワードと表示設定を初期化しますか？")) return;
      localStorage.removeItem(STORAGE_KEY);
      settings = loadSettings();
      renderKeywordRows();
      applySettingsToUi();
      refreshHighlights();
      setStatus("設定をリセットしました");
    });

    document.getElementById("copyBtn").addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(view.state.doc.toString());
        setStatus("全内容をコピーしました");
      } catch {
        setStatus("コピーできませんでした。ブラウザの権限を確認してください");
      }
    });
    document.getElementById("selectAllBtn").addEventListener("click", () => {
      view.dispatch({ selection: { anchor: 0, head: view.state.doc.length }, scrollIntoView: true });
      view.focus();
    });
    document.getElementById("clearHighlightsBtn").addEventListener("click", () => {
      document.querySelectorAll(".keyword-row input[type=text]").forEach(input => input.value = "");
      syncSettingsFromUi();
      refreshHighlights();
      autoSaveSettings();
      setStatus("検索語をクリアしました");
    });

    function buildHtmlExport() {
      syncSettingsFromUi();
      const text = view.state.doc.toString();
      const ranges = [];
      settings.keywords.forEach(kw => {
        if (!kw.text) return;
        let regex;
        try { regex = makeRegex(kw.text, true); } catch { return; }
        let match;
        let safety = 0;
        while ((match = regex.exec(text)) !== null) {
          if (match[0].length === 0) { regex.lastIndex++; continue; }
          ranges.push({ from: match.index, to: match.index + match[0].length, color: kw.color });
          if (++safety > 20000) break;
        }
      });
      ranges.sort((a, b) => a.from - b.from || b.to - a.to);
      const nonOverlap = [];
      let end = -1;
      for (const r of ranges) {
        if (r.from >= end) { nonOverlap.push(r); end = r.to; }
      }
      let out = "";
      let pos = 0;
      for (const r of nonOverlap) {
        out += escapeHtml(text.slice(pos, r.from));
        out += `<span class="hl" style="background-color:${r.color}">${escapeHtml(text.slice(r.from, r.to))}</span>`;
        pos = r.to;
      }
      out += escapeHtml(text.slice(pos));
      const title = escapeHtml(saveName.value || lastFileName || "highlighted_log");
      return `<!doctype html>\n<html lang="ja">\n<head>\n<meta charset="utf-8">\n<title>${title}</title>\n<style>\nbody{margin:20px;font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;background:#f8fafc;color:#111827;}\npre{padding:16px;border:1px solid #d1d5db;background:#fff;overflow:auto;line-height:1.45;font-family:Consolas,"Cascadia Mono","Noto Sans Mono",monospace;white-space:pre;}\n.hl{border-radius:2px;color:#111827;}\n</style>\n</head>\n<body>\n<h1>${title}</h1>\n<pre>${out}</pre>\n</body>\n</html>\n`;
    }

    function downloadBlob(filename, blob) {
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = filename;
      document.body.appendChild(a);
      a.click();
      a.remove();
      setTimeout(() => URL.revokeObjectURL(url), 1000);
    }

    function updateStatus() {
      const text = view.state.doc.toString();
      const lines = view.state.doc.lines;
      statusRight.textContent = `${lines} 行 / ${text.length.toLocaleString()} 文字`;
    }

    function setStatus(message) {
      statusLeft.textContent = message;
    }

    let autoSaveTimer = 0;
    function autoSaveSettings() {
      clearTimeout(autoSaveTimer);
      autoSaveTimer = setTimeout(() => {
        syncSettingsFromUi();
        localStorage.setItem(STORAGE_KEY, JSON.stringify(settings));
      }, 300);
    }

    function stripExtension(name) {
      return (name || "").replace(/\.[^.]+$/, "");
    }

    function safeFileName(name) {
      return String(name).trim().replace(/[\\/:*?"<>|]/g, "_") || "edited_log";
    }

    function escapeHtml(value) {
      return String(value).replace(/[&<>"']/g, ch => ({
        "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;"
      }[ch]));
    }
  </script>
</body>
</html>
